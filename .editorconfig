[*]
charset=utf-8
end_of_line=lf
insert_final_newline=true
indent_style=space
indent_size=4

[*.json]
indent_style=space
indent_size=2

[*.json5]
indent_style=space
indent_size=2

[{Makefile.*,Makefile,GNUmakefile,makefile,*.mk}]
indent_style=tab
tab_width=4

[{*.yaml,*.yml}]
indent_style=space
indent_size=2
